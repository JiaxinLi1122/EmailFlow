generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String               @id @default(cuid())
  email                       String               @unique
  name                        String?
  image                       String?
  passwordHash                String?
  timezone                    String               @default("UTC")
  gmailAccessToken            String?
  gmailRefreshToken           String?
  gmailTokenExpiry            DateTime?
  gmailConnected              Boolean              @default(false)
  lastSyncAt                  DateTime?
  syncEnabled                 Boolean              @default(true)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  totpEnabled                 Boolean              @default(false)
  totpSecret                  String?
  gmailEmail                  String?
  syncStartDate               DateTime?
  emailProviderReauthRequired Boolean              @default(false)
  emailProviderReauthReason   String?
  emailProviderReauthAt       DateTime?
  emailProviderReauthProvider String?
  isAdmin                     Boolean              @default(false)
  accounts                    Account[]
  digests                     Digest[]
  emails                      Email[]
  failedEmailSyncs            FailedEmailSync[]
  passwordResetTokens         PasswordResetToken[]
  projects                    ProjectContext[]
  protectionRules             ProtectionRule[]
  retentionJobLogs            RetentionJobLog[]
  retentionPolicy             RetentionPolicy?
  sessions                    Session[]
  stepUpChallenges            StepUpChallenge[]
  stepUpTokens                StepUpToken[]
  tasks                       Task[]
  identities                  UserIdentity[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  email             String?
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  deviceName        String    @default("Unknown device")
  deviceType        String    @default("unknown")
  browser           String    @default("Unknown")
  os                String    @default("Unknown")
  ipAddress         String    @default("")
  userAgent         String    @default("")
  lastActiveAt      DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  status            String    @default("active")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deviceFingerprint String?
  isNewDevice       Boolean   @default(false)
  previousTokenHash String?
  rotatedAt         DateTime?
  remember          Boolean   @default(false)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, lastActiveAt(sort: Desc)])
  @@index([userId, expiresAt])
  @@index([previousTokenHash])
}

model Email {
  id               String          @id @default(cuid())
  userId           String
  gmailMessageId   String          @unique
  threadId         String?
  accountEmail     String          @default("")
  subject          String
  sender           String
  recipients       String          @default("")
  bodyPreview      String
  bodyFull         String?
  receivedAt       DateTime
  labels           String          @default("")
  hasAttachments   Boolean         @default(false)
  classification   String?
  classConfidence  Float?
  classReasoning   String?
  isWorkRelated    Boolean?
  processedAt      DateTime?
  createdAt        DateTime        @default(now())
  retentionStatus  RetentionStatus @default(ACTIVE)
  archivedAt       DateTime?
  metadataOnlyAt   DateTime?
  purgedAt         DateTime?
  restorableUntil  DateTime?
  retentionReason  String?
  processingStatus String          @default("done")
  syncBatchId      String?
  attachments      Attachment[]
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskLinks        TaskEmail[]

  @@index([userId, receivedAt(sort: Desc)])
  @@index([userId, classification, receivedAt(sort: Desc)])
  @@index([userId, processingStatus, receivedAt(sort: Desc)])
  @@index([userId, syncBatchId])
  @@index([userId, retentionStatus, receivedAt(sort: Desc)])
}

model Task {
  id                 String      @id @default(cuid())
  userId             String
  title              String
  summary            String
  actionItems        String      @default("")
  status             String      @default("pending")
  urgency            Int?
  impact             Int?
  priorityScore      Int?
  priorityReason     String?
  startDate          DateTime?
  explicitDeadline   DateTime?
  inferredDeadline   DateTime?
  deadlineConfidence Float?
  userSetDeadline    DateTime?
  isUserEdited       Boolean     @default(false)
  userNotes          String?
  checkedActionItems String      @default("[]")
  confirmedAt        DateTime?
  dismissedAt        DateTime?
  completedAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  source             String      @default("manual")
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLinks         TaskEmail[]
}

model TaskEmail {
  id           String @id @default(cuid())
  taskId       String
  emailId      String
  relationship String @default("source")
  email        Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  task         Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, emailId])
}

model Digest {
  id          String   @id @default(cuid())
  userId      String
  period      String
  periodStart DateTime
  periodEnd   DateTime
  content     String
  stats       String   @default("{}")
  createdAt   DateTime @default(now())
  isPreview   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StepUpChallenge {
  id        String    @id @default(cuid())
  userId    String
  otpHash   String    @unique
  action    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action])
}

model StepUpToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  action    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action])
}

model SenderMemory {
  id             String   @id @default(cuid())
  userId         String
  sender         String
  actionCount    Int      @default(0)
  awarenessCount Int      @default(0)
  ignoreCount    Int      @default(0)
  lastUpdated    DateTime @updatedAt

  @@unique([userId, sender])
}

model MatterMemory {
  id                  String          @id @default(cuid())
  userId              String
  title               String
  topic               String          @default("other")
  summary             String
  status              String          @default("open")
  nextAction          String?
  linkedPrimaryTaskId String?
  lastEmailId         String?
  lastMessageAt       DateTime?
  threadCount         Int             @default(0)
  emailCount          Int             @default(0)
  lastClassification  String?
  participants        Json            @default("[]")
  keywords            Json            @default("[]")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  projectContextId    String?
  projectContext      ProjectContext? @relation(fields: [projectContextId], references: [id])
  threads             ThreadMemory[]
}

model UserIdentity {
  id          String           @id @default(cuid())
  userId      String
  name        String
  description String?
  status      String           @default("active")
  keywords    Json             @default("[]")
  hints       Json             @default("[]")
  confidence  Float            @default(1.0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  projects    ProjectContext[]
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model ProjectContext {
  id           String         @id @default(cuid())
  userId       String
  identityId   String?
  name         String
  description  String?
  status       String         @default("active")
  keywords     Json           @default("[]")
  participants Json           @default("[]")
  confidence   Float          @default(1.0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  matters      MatterMemory[]
  identity     UserIdentity?  @relation(fields: [identityId], references: [id])
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([identityId])
}

model FailedEmailSync {
  id             String    @id @default(cuid())
  userId         String
  gmailMessageId String
  threadId       String?
  receivedAt     DateTime?
  subject        String?
  sender         String?
  errorReason    String
  retryCount     Int       @default(0)
  status         String    @default("pending")
  firstFailedAt  DateTime  @default(now())
  lastFailedAt   DateTime  @default(now())
  resolvedAt     DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailMessageId])
}

model ThreadMemory {
  id                 String        @id @default(cuid())
  userId             String
  threadId           String
  title              String
  topic              String        @default("other")
  summary            String
  status             String        @default("open")
  nextAction         String?
  linkedTaskId       String?
  lastEmailId        String?
  lastMessageAt      DateTime?
  emailCount         Int           @default(0)
  lastClassification String?
  participants       Json          @default("[]")
  needsFullAnalysis  Boolean       @default(false)
  confidence         Float         @default(1.0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  matterId           String?
  matter             MatterMemory? @relation(fields: [matterId], references: [id])

  @@unique([userId, threadId])
}

model Attachment {
  id                String    @id @default(cuid())
  emailId           String
  filename          String
  mimeType          String    @default("")
  size              Int       @default(0)
  gmailAttachmentId String?
  purgedAt          DateTime?
  createdAt         DateTime  @default(now())
  email             Email     @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
}

model RetentionPolicy {
  id                            String   @id @default(cuid())
  userId                        String   @unique
  metadataOnlyAfterDays         Int      @default(30)
  purgeAfterDays                Int      @default(90)
  taskDoneArchiveAfterDays      Int      @default(0)
  taskDoneMetadataOnlyAfterDays Int      @default(30)
  taskDoneRestoreWindowDays     Int      @default(30)
  attachmentPurgeAfterDays      Int      @default(60)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProtectionRule {
  id        String             @id @default(cuid())
  userId    String
  ruleType  ProtectionRuleType
  value     String
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ruleType, value])
  @@index([userId])
}

model RetentionJobLog {
  id                String    @id @default(cuid())
  userId            String
  triggeredBy       String    @default("cron")
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  emailsArchived    Int       @default(0)
  emailsMetaOnly    Int       @default(0)
  emailsPurged      Int       @default(0)
  attachmentsPurged Int       @default(0)
  bytesFreed        BigInt    @default(0)
  errorCount        Int       @default(0)
  errors            Json?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt(sort: Desc)])
}

model ErrorLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  error     String
  stack     String?
  createdAt DateTime @default(now())

  @@index([action, createdAt(sort: Desc)])
}

enum RetentionStatus {
  ACTIVE
  ARCHIVED
  METADATA_ONLY
  PURGED
}

enum ProtectionRuleType {
  CONTACT
  DOMAIN
  LABEL
}
