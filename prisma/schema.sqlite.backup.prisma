generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  image        String?
  passwordHash String?
  timezone     String    @default("UTC")

  gmailAccessToken  String?
  gmailRefreshToken String?
  gmailTokenExpiry  DateTime?
  gmailConnected    Boolean   @default(false)

  lastSyncAt  DateTime?
  syncEnabled Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emails  Email[]
  tasks   Task[]
  digests Digest[]

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  deviceName   String   @default("Unknown device")
  deviceType   String   @default("unknown")
  browser      String   @default("Unknown")
  os           String   @default("Unknown")
  ipAddress    String   @default("")
  userAgent    String   @default("")
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, lastActiveAt(sort: Desc)])
  @@index([userId, expiresAt])
}

model Email {
  id             String   @id @default(cuid())
  userId         String
  gmailMessageId String   @unique
  threadId       String?
  accountEmail   String   @default("") // which email account received this
  subject        String
  sender         String
  recipients     String   @default("") // JSON string for SQLite
  bodyPreview    String
  bodyFull       String?
  receivedAt     DateTime
  labels         String   @default("") // JSON string for SQLite
  hasAttachments Boolean  @default(false)

  classification  String?
  classConfidence Float?
  classReasoning  String?
  isWorkRelated   Boolean?

  processedAt DateTime?
  createdAt   DateTime  @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskLinks TaskEmail[]
}

model Task {
  id          String  @id @default(cuid())
  userId      String
  title       String
  summary     String
  actionItems String  @default("") // JSON string for SQLite
  status      String  @default("pending")

  urgency        Int?
  impact         Int?
  priorityScore  Int?
  priorityReason String?

  startDate          DateTime?
  explicitDeadline   DateTime?
  inferredDeadline   DateTime?
  deadlineConfidence Float?
  userSetDeadline    DateTime?

  isUserEdited       Boolean @default(false)
  userNotes          String?
  checkedActionItems String  @default("[]") // JSON array of checked indices
  confirmedAt  DateTime?
  dismissedAt  DateTime?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLinks TaskEmail[]
}

model TaskEmail {
  id           String @id @default(cuid())
  taskId       String
  emailId      String
  relationship String @default("source")

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@unique([taskId, emailId])
}

model Digest {
  id          String   @id @default(cuid())
  userId      String
  period      String
  periodStart DateTime
  periodEnd   DateTime
  content     String
  stats       String   @default("{}") // JSON string for SQLite
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
